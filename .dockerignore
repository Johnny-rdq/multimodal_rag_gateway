# ============================================
# .dockerignore — 构建镜像时排除的文件
# ============================================

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# 环境变量（包含密钥，绝不能打包进镜像）
.env

# 运行时数据（通过 Volume 挂载）
uploads/
my_vector_db/
*.db

# Git
.git/
.gitignore

# IDE
.idea/
.vscode/
*.swp

# 系统
.DS_Store
*.log

# 其他
README.md
CLAUDE.md
docker-compose.yml
